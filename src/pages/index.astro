---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Crea tu primer producto con IA en 30 minutos"
  description="Ve nacer un producto real con IA en 30 minutos. Sin slides. Sin teoría. Gratis. Cada sábado a las 10:30am."
>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-bg">
      <img id="heroBgDay" src="/generated/bg-retro-max-day.jpg" alt="" class="hero-bg-img" />
      <img id="heroBgNight" src="/generated/bg-retro-max-night2.jpg" alt="" class="hero-bg-img" />
      <div class="hero-overlay"></div>
    </div>

    <nav class="nav">
      <a href="/" class="nav-logo">shipit</a>
      <div class="nav-links">
        <a href="#sesiones">Sesiones</a>
        <a href="#comunidad">Comunidad</a>
        <a href="/empieza">Empieza</a>
        <a href="#sesiones" class="nav-cta">Reserva tu plaza</a>
      </div>
    </nav>

    <section class="hero-content">
      <span class="hero-label">// every other saturday @ 10:30am</span>
      <h1 class="hero-title">Crea tu primer producto <em>con IA</em> en 30 minutos</h1>
      <p class="hero-sub">Sin slides. Sin teoría. Solo tú, Claude y un producto real.<br>Cada sábado a las 10:30am. Gratis.</p>
      <a href="#sesiones" class="hero-cta">Reserva tu plaza</a>
    </section>
  </div>

  <!-- Content -->
  <main>
    <section>
      <p class="greeting">Hola,</p>
      <p>
        Soy Daniel y no tengo nada que venderte.
      </p>
      <p>
        Desde diciembre de 2025 el mundo cambió para siempre.
      </p>
      <p>
        Cualquier persona puede construir software con IA, sin saber programar.
      </p>
    </section>

    <section>
      <h2>¿Qué es esto?</h2>
      <p>
        En 30 minutos vas a ver nacer un producto real con IA, desde cero.
      </p>
      <p>
        No es un curso. No es un taller. Es ver qué se puede hacer,
        para que dejes de tener excusas.
      </p>
      <p>
        Sin slides. Sin teoría. Solo crear.
      </p>
      <p>
        Después de la sesión, me quedo resolviendo dudas y te invito a un
        grupo de Telegram gratuito donde juntarte con otros frikis con ganas de construir.
      </p>
      <img src="/demo_cc.png" alt="Sesión en vivo con Claude Code" class="photo" />
    </section>

    <section>
      <h2>Es para ti si</h2>
      <ul>
        <li>No sabes por dónde empezar</li>
        <li>Crees que esto no es para ti</li>
        <li>Eres técnico pero la IA te parece un mundo aparte</li>
        <li>Llevas meses con la misma idea aparcada</li>
        <li>Crees que te estás quedando atrás</li>
      </ul>
    </section>

    <section class="session" id="sesiones">
      <h2>Próximas sesiones</h2>
      <table class="session-table">
        <tbody>
          <tr class="past">
            <td class="session-date">7 mar</td>
            <td class="session-day">Sábado · 10:30am</td>
            <td class="session-status"><span class="badge badge-past">Completa</span></td>
          </tr>
          <tr data-date="2026-03-14">
            <td class="session-date">14 mar</td>
            <td class="session-day">Sábado · 10:30am</td>
            <td class="session-status"><a href="https://luma.com/pbbczfc5" class="badge badge-open" target="_blank" rel="noopener noreferrer">Reservar &rarr;</a></td>
          </tr>
          <tr data-date="2026-03-28">
            <td class="session-date">28 mar</td>
            <td class="session-day">Sábado · 10:30am</td>
            <td class="session-status"><a href="https://luma.com/ze8yzv54" class="badge badge-open" target="_blank" rel="noopener noreferrer">Reservar &rarr;</a></td>
          </tr>
          <tr data-date="2026-04-04">
            <td class="session-date">4 abr</td>
            <td class="session-day">Sábado · 10:30am</td>
            <td class="session-status"><a href="https://luma.com/3k4dlgkc" class="badge badge-open" target="_blank" rel="noopener noreferrer">Reservar &rarr;</a></td>
          </tr>
        </tbody>
      </table>
      <p class="note">Gratis. Plazas limitadas. Cada sábado. Hora de Madrid, España.</p>
    </section>

    <section class="projects" id="comunidad">
      <h2>Lo que se construye dentro</h2>
      <p>Proyectos reales construidos por miembros de la comunidad, con IA.</p>
      <div class="projects-grid">
        <a class="project-card" href="https://app.victhechefcocina.com" target="_blank" rel="noopener noreferrer">
          <img src="/shipitprojects/lavaplatos.png" alt="VicTheChef" loading="lazy" />
          <span class="project-name">VicTheChef</span>
          <span class="project-desc">App de retos de cocina</span>
        </a>
        <a class="project-card" href="https://aleamg.com" target="_blank" rel="noopener noreferrer">
          <img src="/shipitprojects/amg-designer.png" alt="Portfolio AMG" loading="lazy" />
          <span class="project-name">Portfolio AMG</span>
          <span class="project-desc">Portfolio de product designer</span>
        </a>
        <a class="project-card" href="https://5minutejournal.vercel.app" target="_blank" rel="noopener noreferrer">
          <img src="/shipitprojects/diario.png" alt="5 Minute Journal" loading="lazy" />
          <span class="project-name">5 Minute Journal</span>
          <span class="project-desc">Journaling diario con reflexiones</span>
        </a>
        <a class="project-card" href="https://flamme-five.vercel.app" target="_blank" rel="noopener noreferrer">
          <img src="/shipitprojects/cards-speak.png" alt="Flame Five" loading="lazy" />
          <span class="project-name">Flame Five</span>
          <span class="project-desc">Lecturas de tarot con IA</span>
        </a>
      </div>
    </section>

    <section>
      <h2>Quién soy</h2>
      <p>
        Soy Daniel, ingeniero de producto y profesor de programación.
      </p>
      <p>
        Llevo creando software desde 2021. En el último año la IA ha cambiado
        completamente cómo construyo. Quiero enseñarte a hacer lo mismo y crear una comunidad de creadores de habla hispana.
      </p>
      <img src="/vr.webp" alt="Daniel Jiménez" class="photo photo-portrait" />
    </section>

    <footer>
      <p>
        Daniel Jiménez ·
        <a href="https://linkedin.com/in/dan-jimenez-dev" target="_blank" rel="noopener noreferrer">LinkedIn</a> ·
        <a href="https://instagram.com/thales.me" target="_blank" rel="noopener noreferrer">Instagram</a>
      </p>
    </footer>
  </main>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.8s ease;
  }

  #heroBgDay { opacity: 1; }
  #heroBgNight { opacity: 0; }

  .night #heroBgDay { opacity: 0; }
  .night #heroBgNight { opacity: 1; }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 70% 60% at 50% 55%, rgba(0, 0, 0, 0.65) 0%, transparent 100%),
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.7) 0%,
        rgba(0, 0, 0, 0.5) 35%,
        rgba(0, 0, 0, 0.55) 65%,
        rgba(0, 0, 0, 0.88) 100%
      );
  }

  .night .hero-overlay {
    background:
      radial-gradient(ellipse 70% 60% at 50% 55%, rgba(0, 0, 0, 0.5) 0%, transparent 100%),
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.5) 0%,
        rgba(0, 0, 0, 0.3) 35%,
        rgba(0, 0, 0, 0.35) 65%,
        rgba(0, 0, 0, 0.8) 100%
      );
  }

  /* ===== NAV ===== */
  .nav {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 48px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .nav-logo {
    font-family: 'Sentient', serif;
    font-weight: 700;
    font-size: 28px;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #fff;
  }

  .nav-cta {
    font-weight: 500;
    color: #fff !important;
    padding: 10px 24px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition: all 0.25s;
  }

  .nav-cta:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(217, 119, 87, 0.35);
  }

  /* ===== HERO CONTENT ===== */
  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 80px 32px 140px;
    max-width: 960px;
    margin: 0 auto;
    flex: 1;
    justify-content: center;
  }

  .hero-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #fff;
    letter-spacing: 0.02em;
    margin-bottom: 28px;
    background: #D97757;
    padding: 6px 14px;
    border-radius: 4px;
    opacity: 0;
    animation: fadeRise 0.7s ease-out 0.1s forwards;
  }

  .hero-title {
    font-family: 'Sentient', serif;
    font-weight: 400;
    font-size: clamp(38px, 5.8vw, 78px);
    color: #fff;
    line-height: 1.06;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.8), 0 0 60px rgba(0, 0, 0, 0.5);
    opacity: 0;
    animation: fadeRise 0.8s ease-out 0.25s forwards;
  }

  .hero-title em {
    color: #D97757;
    font-style: italic;
  }

  .hero-sub {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
    max-width: 540px;
    margin-top: 28px;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.8), 0 0 40px rgba(0, 0, 0, 0.5);
    opacity: 0;
    animation: fadeRise 0.8s ease-out 0.45s forwards;
  }

  .hero-cta {
    margin-top: 44px;
    font-size: 15px;
    font-weight: 500;
    color: #fff;
    padding: 16px 44px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(217, 119, 87, 0.3);
    box-shadow: 0 0 30px rgba(217, 119, 87, 0.1);
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    opacity: 0;
    animation: fadeRise 0.8s ease-out 0.6s forwards;
  }

  .hero-cta:hover {
    background: rgba(217, 119, 87, 0.12);
    border-color: rgba(217, 119, 87, 0.5);
    box-shadow: 0 0 50px rgba(217, 119, 87, 0.18);
    transform: translateY(-1px);
  }

  @keyframes fadeRise {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== MAIN CONTENT ===== */
  main {
    max-width: 640px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  section {
    margin-bottom: 48px;
  }

  .greeting {
    font-family: 'Sentient', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: #fff;
    margin-bottom: 24px;
  }

  section p {
    color: #999;
    margin-bottom: 16px;
  }

  section p:last-child {
    margin-bottom: 0;
  }

  h2 {
    font-family: 'Sentient', serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }

  /* List */
  ul {
    list-style: none;
    padding: 0;
  }

  li {
    color: #999;
    padding: 6px 0;
    padding-left: 20px;
    position: relative;
  }

  li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: #D97757;
  }

  /* Photos */
  .photo {
    width: 100%;
    margin-top: 24px;
    border-radius: 8px;
    border: 1px solid #222;
  }

  .photo-portrait {
    max-width: 320px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center;
    margin-bottom: 20px;
  }

  /* Projects grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .project-card {
    display: flex;
    text-decoration: none;
    color: inherit;
    flex-direction: column;
    border: 1px solid #222;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    background: rgba(255, 255, 255, 0.02);
  }

  .project-card:hover {
    border-color: #444;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .project-card img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .project-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #eee;
    padding: 12px 14px 2px;
  }

  .project-desc {
    font-size: 0.8rem;
    color: #666;
    padding: 0 14px 12px;
  }

  @media (max-width: 600px) {
    .projects {
      margin-left: -20px;
      margin-right: -20px;
    }

    .projects h2,
    .projects > p {
      padding: 0 20px;
    }

    .projects-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 12px;
      padding: 0 20px;
    }

    .projects-grid::-webkit-scrollbar {
      display: none;
    }

    .project-card {
      flex-shrink: 0;
      width: 200px;
      scroll-snap-align: start;
    }

    .project-name {
      font-size: 0.8rem;
      padding: 10px 10px 2px;
    }

    .project-desc {
      font-size: 0.75rem;
      padding: 0 10px 10px;
    }
  }

  /* Session table */
  .session-table {
    width: 100%;
    border-collapse: collapse;
  }

  .session-table tr {
    border-bottom: 1px solid #1a1a1a;
    transition: background 0.15s ease;
  }

  .session-table tr:last-child {
    border-bottom: none;
  }

  .session-table tr:not(.past):hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .session-table tr.past {
    opacity: 0.35;
  }

  .session-table td {
    padding: 12px 0;
    vertical-align: middle;
  }

  .session-date {
    font-weight: 600;
    color: #eee;
    font-size: 0.9rem;
    white-space: nowrap;
    width: 60px;
  }

  .session-day {
    color: #666;
    font-size: 0.875rem;
  }

  .session-status {
    text-align: right;
  }

  .badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
  }

  .badge-past {
    background: #1a1a1a;
    color: #555;
  }

  .badge-open {
    background: #D97757;
    color: #fff;
    transition: background 0.15s ease;
  }

  .badge-open:hover {
    background: #c4684b;
  }

  .note {
    margin-top: 16px;
    font-size: 0.875rem;
    color: #555 !important;
  }

  /* Footer */
  footer {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid #1a1a1a;
  }

  footer p {
    font-size: 0.875rem;
    color: #555;
  }

  footer a {
    color: #555;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  footer a:hover {
    color: #D97757;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 600px) {
    .nav {
      padding: 16px 20px;
    }

    .nav-links a:not(.nav-cta) {
      display: none;
    }

    .hero-content {
      padding: 60px 20px 100px;
    }

    main {
      padding: 48px 20px;
    }

    .greeting {
      font-size: 1.3rem;
    }

    section {
      margin-bottom: 32px;
    }

    .session-day {
      display: none;
    }

    .session-date {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  // Time-based background switching
  function updateHeroBackground() {
    const hour = new Date().getHours();
    const isNight = hour < 7 || hour >= 19;
    document.querySelector('.hero')?.classList.toggle('night', isNight);
  }

  updateHeroBackground();
  setInterval(updateHeroBackground, 60000);

  // Session auto-past marking
  document.querySelectorAll('.session-table tr[data-date]').forEach(row => {
    const dateStr = row.getAttribute('data-date');
    if (!dateStr) return;
    const eventEnd = new Date(dateStr + 'T11:30:00+01:00');
    if (new Date() > eventEnd) {
      row.classList.add('past');
      const badge = row.querySelector('.badge');
      if (badge) {
        badge.classList.remove('badge-open');
        badge.classList.add('badge-past');
        badge.textContent = 'Pasada';
        if (badge.tagName === 'A') {
          const span = document.createElement('span');
          span.className = badge.className;
          span.textContent = badge.textContent;
          badge.replaceWith(span);
        }
      }
    }
  });
</script>
